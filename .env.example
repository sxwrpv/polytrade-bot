# --- Polymarket referral code (embedded in onboarding redirects) ---
REFERRAL_CODE=your_code_here

# --- Database ---
# Postgres/Supabase DSN. When set, the app uses Postgres (asyncpg); when empty,
# it falls back to local SQLite at DB_PATH. Get the password from the Supabase
# dashboard: project -> Settings -> Database -> reset password; then:
#   postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres
DATABASE_URL=
DB_PATH=copybot.db

# --- On-chain detection (optional) ---
# Polygon JSON-RPC HTTP URL. If set, the engine detects leader trades from
# OrderFilled logs (~2-4s, attributed) instead of activity polling (~3-8s).
# Use your own Alchemy/Infura endpoint for production; public RPCs rate-limit.
POLYGON_RPC_URL=

# --- Copy engine ---
# Fast trade detection (per leader); tighter than reconciliation.
DETECTION_POLL_SECONDS=2
COPY_ENGINE_POLL_SECONDS=30
DEFAULT_ALLOCATION_PCT=10.0
DEFAULT_MAX_POSITION_USD=50.0
MAX_COPY_SLIPPAGE_PCT=2.0

# --- Security ---
# Encrypts signer private keys at rest (AES-256-GCM). MUST be a strong random value in prod.
ENCRYPTION_SECRET=change_me_in_production

# --- Server ---
HOST=0.0.0.0
PORT=8080

# --- Polymarket builder/relayer credentials (gasless deposit-wallet trading) ---
# Get these from polymarket.com/settings?tab=builder. Required for gasless
# (deposit-wallet) mode via polymarket-client's AsyncSecureClient; without them
# the app falls back to EOA mode (needs a little MATIC for the one-time
# allowance). See BUILD_PLAN.md §wallet model.
POLYMARKET_BUILDER_API_KEY=
POLYMARKET_BUILDER_SECRET=
POLYMARKET_BUILDER_PASSPHRASE=
POLYMARKET_BUILDER_CODE=   # 0x… builder code — stamped on every order (volume attribution + builder fees)
RELAYER_API_KEY=
RELAYER_API_KEY_ADDRESS=

# --- Telegram Mini App ---
# Bot token from @BotFather. Enables Telegram login + account linking (the
# Mini App signs users in automatically via initData). Optional — without it
# the app runs as a plain web app.
TELEGRAM_BOT_TOKEN=
# Bot username (without @) — builds the t.me share/referral deep link.
TELEGRAM_BOT_USERNAME=

# --- Abuse guards ---
# Wallet creations allowed per IP, as "count/window_seconds".
CREATE_WALLET_RATE_LIMIT=3/3600

# --- Wallet screener crawler ---
# How many active wallets each discovery pass crawls from the public
# leaderboard feeds (~target/50 API calls), and how many of the stalest get
# their windowed 7/30/90d stats recomputed per pass (2 calls each, concurrent).
DISCOVER_WALLETS_TARGET=2000
TRADER_STATS_REFRESH_LIMIT=200
TRADER_STATS_REFRESH_CONCURRENCY=4
